{
  "name": "Notesok",
  "short_name": "Notesok",
  "description": "Offline markdown notes in your browser",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#1e1e1e",
